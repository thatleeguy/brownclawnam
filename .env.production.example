APP_NAME="Brownclaw Asset Management"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://brownclawam.ca
APP_TIMEZONE=America/Edmonton

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# MySQL on Forge by default
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=brownclawam
DB_USERNAME=forge
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local

# Mail — pick a provider. Postmark / Resend recommended for transactional from a small operator.
MAIL_MAILER=log
# MAIL_MAILER=postmark
# POSTMARK_TOKEN=
MAIL_FROM_ADDRESS="info@brownclawam.ca"
MAIL_FROM_NAME="${APP_NAME}"

# Optional admin notification
INBOX_NOTIFY_TO=connor@brownclawam.ca

VITE_APP_NAME="${APP_NAME}"
